# =============================================
# REI Survey Template — Environment Variables
# Copy to .env.local for local development
# Set all of these in Vercel for production
# =============================================

# --- Brand ---
COMPANY_NAME="Your Home Buyers"
PHONE_DISPLAY="(800) 000-0000"
PHONE_HREF="8000000000"
ACCENT_COLOR="#2563eb"
LOGO_URL=""

# --- Hero Content ---
HEADLINE="Sell Your House Fast For Cash"
SUBHEADLINE="No fees. No repairs. Cash offer in 24 hours."

# --- Trust Indicators ---
STAT_1_VALUE="1,000+"
STAT_1_LABEL="Homes Purchased"
STAT_2_VALUE="10+"
STAT_2_LABEL="Years in Business"
STAT_3_VALUE="24 Hrs"
STAT_3_LABEL="Cash Offer"

# --- SEO ---
META_TITLE="Sell Your House Fast For Cash | Your Home Buyers"
META_DESCRIPTION="Get a fair cash offer for your home in 24 hours. No fees, no repairs, no hassle."

# --- Footer Links ---
PRIVACY_POLICY_URL="/privacy"
TERMS_URL="/terms"

# --- Survey disqualification (optional, comma-separated property type IDs) ---
# Valid IDs: single-family, multi-family, condo-townhouse, mobile-home, land, other
# DISQUALIFIED_PROPERTY_TYPES="mobile-home,land,other"

# --- Integrations (server-side, never exposed to browser) ---
WEBHOOK_URL=""
# GoFunnel external / custom-webhook credential for server-side lead forwarding.
# Per-client (set both in each deployment). Leave blank to disable the forward.
GOFUNNEL_WEBHOOK_CREDENTIAL_ID=""
GOFUNNEL_WEBHOOK_SECRET=""

# --- Client-side integrations (NEXT_PUBLIC_ prefix required) ---
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=""
# GoFunnel attribution tracking org (client) id. Per-client; blank disables tracking.
NEXT_PUBLIC_GOFUNNEL_ORG_ID=""
NEXT_PUBLIC_FB_PIXEL_ID=""
NEXT_PUBLIC_VIDALYTICS_ACCOUNT_ID=""
NEXT_PUBLIC_VIDALYTICS_EMBED_ID=""

# --- Thank You page video (leave blank to hide) ---
NEXT_PUBLIC_THANKYOU_VIDEO_URL=""
